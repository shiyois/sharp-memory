## Standard .gitignore for modern .NET projects.
## Based on GitHub's Dotnet/VisualStudio ignore patterns, with local
## sharp-memory development files added at the end.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
.artifacts/

# .NET
project.lock.json
project.fragment.lock.json
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
packages/
*.nuget.props
*.nuget.targets

# MSBuild logs
*.binlog
[Bb]uild[Ll]og.*

# Test results and coverage
[Tt]est[Rr]esult*/
[Tt]est[Rr]esults/
TestResult.xml
nunit-*.xml
*.VisualState.xml
CodeCoverage/
coverage/
coverage.*
*.coverage
*.coveragexml

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.DotSettings.user

# ASP.NET scaffolding
ScaffoldingReadMe.txt

# Local environment
.env
.env.*
!*.env.example
settings.json

# OS/editor temporary files
~$*
*~
*.tmp
*.temp
Thumbs.db
.DS_Store

# Agent/local workspace files
.claude/
.tmp/
.pi/*
!.pi/extensions/
!.pi/extensions/**

# Project-specific local caches
.sharp-memory/
.benchmark-cache/
